{
  "entities": {
    "BlogPost": {
      "title": "Blog Post",
      "description": "A blog post written by the author.",
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "description": "The title of the blog post."
        },
        "content": {
          "type": "string",
          "description": "The full content of the blog post (Markdown or HTML)."
        },
        "excerpt": {
          "type": "string",
          "description": "A short summary of the blog post."
        },
        "imageUrl": {
          "type": "string",
          "description": "The URL of the post's image."
        },
        "videoUrl": {
          "type": "string",
          "description": "The URL of the post's video."
        },
        "authorId": {
          "type": "string",
          "description": "The UID of the author."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the post was created."
        },
        "published": {
          "type": "boolean",
          "description": "Whether the post is visible to the public."
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Tags for categorization."
        }
      },
      "required": ["title", "content", "authorId", "createdAt", "published"]
    },
    "Message": {
      "title": "Contact Message",
      "description": "A message sent from the contact form.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of the sender."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "Email address of the sender."
        },
        "message": {
          "type": "string",
          "description": "The message content."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the message was sent."
        }
      },
      "required": ["name", "email", "message", "createdAt"]
    },
    "User": {
      "title": "User Profile",
      "description": "User profile data, used to identify admins.",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "format": "email"
        },
        "role": {
          "type": "string",
          "enum": ["admin", "user"]
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["email", "role", "createdAt"]
    },
    "Book": {
      "title": "Book",
      "description": "A book available for purchase.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "string" },
        "coverImage": { "type": "string" },
        "purchaseLinks": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "url": { "type": "string" },
              "icon": { "type": "string" }
            }
          }
        },
        "readFirstPagesLink": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "description", "price", "createdAt"]
    },
    "Order": {
      "title": "Order",
      "description": "A purchase order.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "address": { "type": "string" },
        "format": { "type": "string" },
        "price": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "price", "createdAt"]
    },
    "Subscriber": {
      "title": "Subscriber",
      "description": "A newsletter subscriber.",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "createdAt"]
    }
  },
  "firestore": {
    "posts/{postId}": {
      "schema": {
        "$ref": "#/entities/BlogPost"
      },
      "description": "Collection of blog posts."
    },
    "messages/{messageId}": {
      "schema": {
        "$ref": "#/entities/Message"
      },
      "description": "Collection of contact messages."
    },
    "users/{userId}": {
      "schema": {
        "$ref": "#/entities/User"
      },
      "description": "Collection of user profiles."
    },
    "books/{bookId}": {
      "schema": {
        "$ref": "#/entities/Book"
      },
      "description": "Collection of books."
    },
    "orders/{orderId}": {
      "schema": {
        "$ref": "#/entities/Order"
      },
      "description": "Collection of orders."
    },
    "subscribers/{subscriberId}": {
      "schema": {
        "$ref": "#/entities/Subscriber"
      },
      "description": "Collection of subscribers."
    }
  }
}
